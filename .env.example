# ─── Supabase ───────────────────────────────────────────────────────────────
# Retrieve from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Retrieve from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── n8n / AI News ───────────────────────────────────────────────────────────
# Token secret used by n8n to ingest AI News articles (x-ingest-token header)
N8N_AI_NEWS_INGEST_TOKEN=
N8N_WEBHOOK_URL_ANALYZE=
N8N_CALLBACK_BASE_URL=
